{
  "name": "mentor-studio-code",
  "displayName": "Mentor Studio Code",
  "description": "Track your learning progress and review history with AI mentor sessions in VS Code",
  "version": "0.2.0",
  "icon": "images/icon.png",
  "license": "MIT",
  "publisher": "nabetxan",
  "repository": {
    "type": "git",
    "url": "https://github.com/nabetxan/mentor-studio-code"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Education"
  ],
  "activationEvents": [
    "workspaceContains:.mentor/config.json"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mentor-studio",
          "title": "Mentor Studio Code",
          "icon": "$(mortar-board)"
        }
      ]
    },
    "views": {
      "mentor-studio": [
        {
          "type": "webview",
          "id": "mentor-studio.sidebar",
          "name": "",
          "icon": "$(mortar-board)",
          "when": "workspaceFolderCount > 0"
        }
      ]
    },
    "commands": [
      {
        "command": "mentor-studio.setup",
        "title": "Setup Mentor",
        "category": "Mentor Studio Code"
      },
      {
        "command": "mentor-studio.removeMentor",
        "title": "Remove Mentor",
        "category": "Mentor Studio Code"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "vscode:uninstall": "node scripts/uninstall.js"
  },
  "dependencies": {
    "@mentor-studio/shared": "*"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "@types/vscode": "~1.85.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
