{
  "name": "mentor-studio-code",
  "displayName": "Mentor Studio Code",
  "description": "An AI-mentor extension for VS Code, optimized for use with Claude Code. Track your understanding, spot your weak points, and keep learning in your own projects.",
  "version": "0.6.3",
  "icon": "images/icon.png",
  "license": "MIT",
  "publisher": "nabetxan",
  "repository": {
    "type": "git",
    "url": "https://github.com/nabetxan/mentor-studio-code"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "keywords": [
    "mentor",
    "learning",
    "code review",
    "Claude",
    "education"
  ],
  "categories": [
    "Education",
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:.mentor/config.json"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mentor-studio",
          "title": "Mentor Studio Code",
          "icon": "$(mortar-board)"
        }
      ]
    },
    "views": {
      "mentor-studio": [
        {
          "type": "webview",
          "id": "mentor-studio.sidebar",
          "name": "",
          "icon": "$(mortar-board)",
          "when": "workspaceFolderCount > 0"
        }
      ]
    },
    "commands": [
      {
        "command": "mentor-studio.setup",
        "title": "Setup Mentor",
        "category": "Mentor Studio Code"
      },
      {
        "command": "mentor-studio.removeMentor",
        "title": "Remove Mentor",
        "category": "Mentor Studio Code"
      },
      {
        "command": "mentor-studio.openPlanPanel",
        "title": "Open Plan Panel",
        "category": "Mentor Studio Code"
      },
      {
        "command": "mentor-studio.addFilesToPlan",
        "title": "Add to Mentor Plan",
        "category": "Mentor Studio Code"
      },
      {
        "command": "mentor-studio.setFileAsSpec",
        "title": "Add to Mentor Spec",
        "category": "Mentor Studio Code"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "mentor-studio.addFilesToPlan",
          "when": "resourceExtname == .md && workspaceFolderCount > 0",
          "group": "mentor@1"
        },
        {
          "command": "mentor-studio.setFileAsSpec",
          "when": "resourceExtname == .md && workspaceFolderCount > 0",
          "group": "mentor@2"
        }
      ],
      "editor/title/context": [
        {
          "command": "mentor-studio.addFilesToPlan",
          "when": "resourceExtname == .md",
          "group": "mentor@1"
        },
        {
          "command": "mentor-studio.setFileAsSpec",
          "when": "resourceExtname == .md",
          "group": "mentor@2"
        }
      ]
    }
  },
  "scripts": {
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "vscode:uninstall": "node scripts/uninstall.js"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@mentor-studio/shared": "*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql.js": "^1.10.3"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/sql.js": "^1.4.11",
    "@types/vscode": "~1.85.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
