  "private": true,
  "workspaces": [
    "packages/*",
    "extension",
    "extension/webview"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "build": "npm run build --workspaces",
    "package:extension": "npm run build && npm --prefix extension run package:vsix",
    "test": "npm run test --workspaces --if-present"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.9.1"
  }
}
